{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "lib": [
        "ES2022",
        "DOM",
        "DOM.Iterable"
      ],
      "rootDir": "./src",
      "outDir": "./dist",
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true,
      "strict": true,
      "noUncheckedIndexedAccess": true,
      "skipLibCheck": true,
      "esModuleInterop": true,
      "verbatimModuleSyntax": true
    },
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "dist",
      "node_modules"
    ]
  }